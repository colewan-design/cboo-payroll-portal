{
  "expo": {
    "name": "BSU CBOO Payroll",
    "slug": "bsu-cboo-payroll-portal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bsu-logo.png",
    "scheme": "bsucboopayrollportal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/images/bsu-logo.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.teekunana.bsucboopayrollportal"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/bsu-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#1B5E20",
          "dark": {
            "backgroundColor": "#1B5E20"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea9bac0d-ba93-4d61-b4f1-511b7195695f"
      }
    },
    "owner": "teekunana"
  }
}
